@host = http://localhost:5113

### Structured filter - no filters (returns all books)
POST {{host}}/api/books/filter
Content-Type: application/json

{
  "title": null,
  "genre": null,
  "language": null,
  "publisher": null,
  "format": null,
  "yearFrom": null,
  "yearTo": null,
  "priceFrom": null,
  "priceTo": null,
  "pageCountFrom": null,
  "pageCountTo": null,
  "minRating": null,
  "isAvailable": null,
  "sortBy": null,
  "sortDirection": null
}

###

### Structured filter - filter by genre
POST {{host}}/api/books/filter
Content-Type: application/json

{
  "genre": "Fiction",
  "sortBy": "title",
  "sortDirection": "asc"
}

###

### Structured filter - filter by price range, sorted by price ascending
POST {{host}}/api/books/filter
Content-Type: application/json

{
  "priceFrom": 10,
  "priceTo": 50,
  "sortBy": "price",
  "sortDirection": "asc"
}

###

### Structured filter - filter by year range and language
POST {{host}}/api/books/filter
Content-Type: application/json

{
  "yearFrom": 2010,
  "yearTo": 2020,
  "language": "English",
  "sortBy": "year",
  "sortDirection": "desc"
}

###

### Structured filter - filter by minimum rating, only available books
POST {{host}}/api/books/filter
Content-Type: application/json

{
  "minRating": 4.0,
  "isAvailable": true,
  "sortBy": "rating",
  "sortDirection": "desc"
}

###

### Structured filter - filter by format and page count range
POST {{host}}/api/books/filter
Content-Type: application/json

{
  "format": "E-Book",
  "pageCountFrom": 100,
  "pageCountTo": 400,
  "sortBy": "pagecount",
  "sortDirection": "asc"
}

###

### Structured filter - filter by publisher and title keyword
POST {{host}}/api/books/filter
Content-Type: application/json

{
  "title": "the",
  "publisher": "Penguin",
  "sortBy": "title",
  "sortDirection": "asc"
}

###


### Dynamic filter - no filter, no sort (returns all books)
POST {{host}}/api/books
Content-Type: application/json

{
  "filter": null,
  "sort": null
}

### Dynamic filter - filter by genre Fiction
POST {{host}}/api/books
Content-Type: application/json

{
  "filter": "x => x.Genre == 'Fiction'",
  "sort": null
}

###

### Dynamic filter - filter by rating and sort by price descending
POST {{host}}/api/books
Content-Type: application/json

{
  "filter": "x => x.Rating >= 4.0",
  "sort": "x => x.Price"
}

###

### Dynamic filter - filter available books under $30
POST {{host}}/api/books
Content-Type: application/json

{
  "filter": "x => x.IsAvailable == true && x.Price < 30",
  "sort": "x => x.Title"
}